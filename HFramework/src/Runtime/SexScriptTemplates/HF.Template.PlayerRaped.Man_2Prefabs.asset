  m_Script: {fileID: 11500000, guid: 27d0f48dd1605444b8b1baaf01072313, type: 3}
  m_Name: HF.Template.PlayerRaped.Man_2Prefabs
  m_EditorClassIdentifier: 
  EngineVersion: 0
  UniqueID: 
  Name: 
  Description: "Template for PlayerRaped scenes for Man based on the original game.\r\n\r\nThis
    assumes 2 prefabs are used, 1 for Battle, 1 for Sex\r\n\r\nYou should set:\r\n1.
    MakeBattlePrefab >  Instantiator\r\n2. MakeSexPrefab >  Instantiator\r\n\r\nAssumes:\r\n1.
    It is using the SexList approach (new prefab)\r\n2. SkeletonAnim is on Scale/Anim\r\n3.
    Npc 0 is rapist Female NPC\r\n4. Npc 1 is victim Player\r\n5. There is a vagina
    penetration and a creampie (Player -> Rapist)\r\n6. Animations in Battle prefab
    are:\r\n  - A_Attack_loop\r\n  - A_Attack_giveup\r\n7. Animations in Sex prefab
    are:\r\n  - A_AttackToSex\r\n  - A_Loop_01\r\n  - A_Loop_02\r\n  - A_Finish\r\n 
    - A_Finish_idle\r\n"
  MinimalGameVersion: 0.0.0.0
  RequiresDLC: 0
  Info:
    ContextTags:
    - Forced
    Npcs:
    - NpcID: 15
      FaintCondition:
        Expected: 1
      DeadCondition:
        Expected: 1
      Conditions: []
    - NpcID: 1
      FaintCondition:
        Expected: 0
      DeadCondition:
        Expected: 2
      Conditions: []
    NpcOrderMatters: 1
    StartConditions: []
    ExecuteConditions: []
