  m_Name: HF.Template.AssWall
  m_EditorClassIdentifier: 
  EngineVersion: 0
  UniqueID: HF.Template.AssWall
  Name: 
  Description: "Template for AssWall scenes based on the original game.\n\nAssumes:\n1.
    It is targeting a world object (AssWall structure)\n2. Npc 0 is Male player\n3.
    Npc 1 is \"Toileted\" female NPC\n4. Animations are:\n  - A_idle\n  - [NPCID]_A_Loop_01\n 
    - [NPCID]_A_Loop_02\n  - [NPCID]_A_Finish\n  - [NPCID]_A_Finish_idle\n\nWhere
    [NPCID] is the NPCs[1]"
  MinimalGameVersion: 0.0.0.0
  RequiresDLC: 0
  Info:
    ContextTags:
    - Toilet
    Npcs:
    - NpcID: 1
      FaintCondition:
        Expected: 0
      DeadCondition:
        Expected: 0
      Conditions: []
    - NpcID: 15
      FaintCondition:
        Expected: 0
      DeadCondition:
        Expected: 0
      Conditions: []
