  m_Name: HF.Template.CommonSexPlayer.YonaxM
  m_EditorClassIdentifier: 
  EngineVersion: 0
  UniqueID: 
  Name: 
  Description: "Template for Male NPC x Yona scenes based on the original game, with
    option to toggle man and only 1 pose (no alternate pose)\n\nYou should set:\n1.
    MakeSexPrefab >  Instantiator\n2. If you don't have a way to toggle man, disable
    the menu items in all menus\n\nAssumes:\n1. It is using the SexList approach\n2.
    SkeletonAnim is on Scale/Anim\n3. Npc 0 is Male NPC\n4. Npc 1 is Female Player\n5.
    There is a vagina penetration and a creampie\n6. Animations are:\n  - A_idle\n 
    - A_Contact_01\n  - A_Loop_01\n  - A_Loop_02\n  - A_Finish\n  - A_Finish_idle\n7.
    Toggles man with TrackIndex = 10, Animation \"noman\"\n"
  MinimalGameVersion: 0.0.0.0
  RequiresDLC: 0
  Info:
    ContextTags:
    - Normal
    Npcs:
    - NpcID: 10
      FaintCondition:
