GridBackground {
    --grid-background-color: rgb(40, 40, 40);
    --line-color: rgba(193, 196, 192, 0.1);
    --thick-line-color: rgba(193, 196, 192, 0.1);
    --spacing: 15;
}

NodeView.warning {
    background-color: rgba(255, 247, 0, 255);
}

NodeView.error {
    background-color: rgb(255, 13, 0);
}
